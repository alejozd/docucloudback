# Variables de entorno para el sistema de licenciamiento

# API Key para proteger el endpoint de generación de licencias offline
API_KEY=tu-api-key-secreta-cambia-esto

# Clave secreta para firmar licencias offline
LICENCIA_SECRET_KEY=tu-clave-secreta-para-licencias-cambia-esto

# Clave secreta para validar códigos de registro HMAC SHA256 (debe ser larga y segura)
LICENSE_SECRET=mi_clave_super_secreta_123_cambiar_en_produccion

# Configuración de base de datos (ya existente)
DB_NAME=nombre_base_datos
DB_USER=usuario
DB_PASSWORD=contrasena
DB_HOST=localhost

# Puerto del servidor
PORT=3100

# Entorno
NODE_ENV=development

# JWT Secret (ya existente si usas autenticación)
JWT_SECRET=tu-jwt-secret

# ==========================================
# Telegram Bot Configuration (FSE Monitor)
# ==========================================
# Token del bot obtenido de @BotFather
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui

# Tu Chat ID personal (obtenido de @userinfobot)
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# URL del webhook (debe ser HTTPS y apuntar a tu dominio)
TELEGRAM_WEBHOOK_URL=https://api.zdevs.uk/telegram/webhook

# ==========================================
# FSEconomy API Keys (FSE Monitor)
# ==========================================
# Userkey de tu cuenta FSEconomy (Settings → Data Feeds)
FSE_USERKEY=tu_userkey_aqui

# Read key generada para acceso a Data Feeds
FSE_READ_KEY=tu_read_key_aqui

# ==========================================
# Debug Flags (true/false)
# ==========================================
# Controla logs de debug sin tocar código
DEBUG_TELEGRAM=false
DEBUG_FSE=false
DEBUG_PARSER=false
DEBUG_JOBS=false

# === API Security ===
ZAM_API_KEY=change-me-to-a-secure-string-32+chars

# ==========================================
# Audio Download Configuration (YouTube)
# ==========================================
# Ruta donde se guardarán los archivos MP3 descargados
# Si no se especifica, se usará: ./downloads/audios
AUDIO_DOWNLOAD_PATH=/var/www/audio_downloads
