# Variables de entorno para el sistema de licenciamiento

# Clave secreta para firmar licencias offline (cambiar por una segura en producción)
SECRET_KEY=tu_clave_secreta_muy_segura_cambiala_en_produccion

# API KEY para proteger el endpoint de generación de licencias offline
API_KEY=tu_api_key_para_licencias_offline_cambiala_en_produccion

# Configuración de base de datos (ya existente)
DB_NAME=docucloud
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost

# Puerto del servidor
PORT=3100

# Entorno (development/production)
NODE_ENV=development

# JWT Secret para autenticación (ya existente)
JWT_SECRET=tu_jwt_secret
